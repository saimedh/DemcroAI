# ============================================================
# DemocrAI — Environment Variables
# Copy to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ============================================================

# --- Gemini / Google AI ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Civic Information API ---
# Get from: https://console.cloud.google.com → Civic Information API
GOOGLE_CIVIC_API_KEY=your_civic_api_key_here

# --- Ballotpedia API (optional, enhances candidate bios) ---
# Request at: https://ballotpedia.org/Ballotpedia:API_support
BALLOTPEDIA_API_KEY=

# --- Firebase Admin (for Firestore flagging + ballot cache) ---
# Option A: Paste entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: Individual fields (if not using Option A)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
